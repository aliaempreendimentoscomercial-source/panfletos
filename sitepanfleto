          ];
        }
        return [
          { key: "verso", label: state.folderSide === "back" ? "Frente" : "Verso", kind: "flip" }
        ];
      }
      return currentFold().states;
    }

    function pageName(index) {
      if (state.product === "packaging") return FACE_NAMES[index] || `Face ${index + 1}`;
      return `Página ${index + 1}`;
    }

    function imageForPageNumber(pageNumber) { return state.images[pageNumber - 1]; }

    function pageMarkupByNumber(pageNumber, opts = {}) {
      const index = pageNumber - 1;
