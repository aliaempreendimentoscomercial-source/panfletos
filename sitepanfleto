    function getRatio() {
      if (state.product === "packaging") return { label: "Faces 3D", text: `${state.boxWidth}×${state.boxHeight}×${state.boxDepth}`, w: state.boxWidth, h: state.boxHeight };
      if (state.ratioPreset === "custom") return { label: "Personalizada", text: `${state.customW}:${state.customH}`, w: state.customW || 1, h: state.customH || 1 };
      if (state.ratioPreset === "auto") return { label: "Automática", text: state.autoW && state.autoH ? `${state.autoW}:${state.autoH}` : "aguardando imagem", w: state.autoW || 1, h: state.autoH || 1.414 };
      return RATIO_PRESETS[state.ratioPreset];
    }

    function currentFold() { return FOLD_MODELS[state.foldModel]; }

    // LÓGICA UNIVERSAL DE VERSO
    // Para qualquer material frente/verso: verso da página X = total de páginas + 1 - X.
    // Exemplo com 6 páginas: 1 ⇄ 6, 2 ⇄ 5, 3 ⇄ 4.
    function backPageFor(pageNumber, totalPages) {
      return totalPages + 1 - pageNumber;
    }

    function frontPanelsForTotal(totalPages) {
      const visiblePanels = Math.max(1, Math.ceil(totalPages / 2));
      return Array.from({ length: visiblePanels }, (_, index) => index + 1);
    }

    function backPanelsFor(frontPanels, totalPages) {
      return frontPanels.map(pageNumber => backPageFor(pageNumber, totalPages));
    }

    function getFolderFrontPanels(fold = currentFold()) {
      const totalPages = fold.pages || expectedCount();
      return frontPanelsForTotal(totalPages);
    }

    function getFolderBackPanels(frontPanels, fold = currentFold()) {
      const totalPages = fold.pages || expectedCount();
      return backPanelsFor(frontPanels, totalPages);
    }

    function getFolderMaxOpenStep(fold = currentFold()) {
      return Math.max(1, getFolderFrontPanels(fold).length - 1);
    }

    function expectedCount() {
      if (state.product === "packaging") return 6;
      if (state.product === "frontBack") return 2;
      if (state.product === "folder") return currentFold().pages;
      return state.pageCount;
    }

    function uploadedCount() { return Object.keys(state.images).filter(k => Number(k) < expectedCount() && state.images[k]).length; }

    function normalize() {
      if (state.product === "frontBack") state.pageCount = 2;
      if (state.product === "packaging") state.pageCount = 6;
      if (state.product === "folder") {
        state.pageCount = currentFold().pages;
        state.openPct = Math.max(0, Math.min(100, Number(state.openPct ?? 100)));
        state.openStep = Math.round((state.openPct / 100) * getFolderMaxOpenStep(currentFold()));
        if (!["front", "back"].includes(state.folderSide)) state.folderSide = "front";
      }

      const states = getStates();
      if (!states.some(s => s.key === state.view) && state.product !== "folder") {
        state.view = states[0] ? states[0].key : "";
      }

      Object.keys(state.images).forEach(k => { if (Number(k) >= expectedCount()) delete state.images[k]; });
      state.bookSpread = Math.min(state.bookSpread, Math.max(0, Math.floor((state.pageCount - 4) / 2)));
    }

    function getStates() {
      if (state.product === "book") {
        return [
          { key: "cover", label: "Capa" },
          { key: "prevPage", label: "← Página" },
          { key: "spread", label: `Miolo ${state.bookSpread + 1}` },
          { key: "nextPage", label: "Página →" },
