    function panelAnimFor(mode, index, count) {
      if (!mode || mode === "none") return { from: 0, origin: "center center" };
      if (mode === "book") {
        return index === 0
          ? { from: 150, origin: "right center" }
          : { from: -150, origin: "left center" };
      }
      if (mode === "roll") return { from: -125, origin: "left center" };
      if (mode === "z") {
        return index % 2 === 0
          ? { from: -110, origin: "left center" }
          : { from: 110, origin: "right center" };
      }
      if (mode === "gate") {
        return index < count / 2
          ? { from: 120, origin: "right center" }
          : { from: -120, origin: "left center" };
      }
      if (mode === "parallel") {
        return index < 2
          ? { from: -130, origin: "left center" }
          : { from: 130, origin: "right center" };
      }
      return { from: -90, origin: "left center" };
    }

    function renderFlatPages(pageNumbers, opts = {}) {
      const ratio = getRatio();
      const cols = opts.cols || pageNumbers.length;
      const targetHeight = cols === 1 ? 520 : cols === 2 ? 430 : 360;
      const width = Math.max(280, Math.min(1320, targetHeight * (ratio.w / ratio.h) * cols));
      const doc = document.createElement("div");
      const classes = ["flat-doc"];
      if (opts.gap) classes.push("has-gap");
      if (opts.opening) classes.push("opening-doc");
      if (opts.openingMode) {
        classes.push("fold-opening");
        classes.push(`mode-${opts.openingMode}`);
      }
      if (opts.flipped) classes.push("fold-back-flip");
      doc.className = classes.join(" ");
      doc.style.setProperty("--cols", cols);
      doc.style.setProperty("--doc-width", `${width}px`);
      doc.style.setProperty("--mobile-doc-width", `${Math.max(760, width)}px`);
      doc.style.setProperty("--page-w", ratio.w);
      doc.style.setProperty("--page-h", ratio.h);
      doc.style.setProperty("--gap", opts.gap ? "12px" : "0px");
      doc.innerHTML = pageNumbers.map((n, i) => {
        const anim = opts.openingMode ? panelAnimFor(opts.openingMode, i, pageNumbers.length) : null;
        return pageMarkupByNumber(n, {
          round: `${i === 0 ? "round-left" : ""} ${i === pageNumbers.length - 1 ? "round-right" : ""}`,
          panelIndex: i,
          panelFrom: anim ? anim.from : null,
          panelOrigin: anim ? anim.origin : null
        });
      }).join("");
      els.viewer.innerHTML = "";
      els.viewer.appendChild(doc);
    }

    function clampNumber(value, min, max) {
      return Math.max(min, Math.min(max, Number(value) || 0));
    }

    function syncOpenStepFromPct() {
      const folds = getFolderMaxOpenStep(currentFold());
      state.openPct = clampNumber(state.openPct, 0, 100);
      state.openStep = Math.round((state.openPct / 100) * folds);
    }

    let foldRangeFrame = null;
    function updateFoldRangeVisual(rangeWrap) {
      if (!rangeWrap) return;
      const pct = clampNumber(state.openPct, 0, 100);
      const label = rangeWrap.querySelector('.fold-range-label strong');
      const progress = rangeWrap.querySelector('.open-progress > span');
      const input = rangeWrap.querySelector('#foldOpenRange');
      if (label) label.textContent = `${Math.round(pct)}%`;
      if (progress) progress.style.width = `${pct}%`;
      if (input && Number(input.value) !== pct) input.value = pct;
    }

    function requestFolderFluidRender(rangeWrap) {
      updateFoldRangeVisual(rangeWrap);
      if (foldRangeFrame) cancelAnimationFrame(foldRangeFrame);
      foldRangeFrame = requestAnimationFrame(() => {
        foldRangeFrame = null;
        syncOpenStepFromPct();
        renderViewer();
        updateSummary();
      });
    }

    function physicalPageMarkupByNumber(pageNumber, opts = {}) {
      const index = pageNumber - 1;
      const image = state.images[index];
      const title = opts.title || `Pág ${pageNumber}`;
      const badge = opts.badge || `Página ${pageNumber}`;
      return `
        <article class="page ${opts.round || ""}" style="${opts.style || ""}" data-index="${index}">
          <div class="placeholder"><div class="placeholder-inner"><div class="placeholder-icon">+</div><span>Envie a imagem da ${badge}</span></div></div>
          ${image ? `<img class="page-media" src="${image.src}" alt="${badge}">` : ""}
          <div class="page-title">${title}</div>
          <div class="page-badge">${badge}</div>
        </article>
      `;
    }

    function getPhysicalFoldRelativeAngles(mode, count, closedAngle) {
      const hinges = Math.max(0, count - 1);
      if (hinges === 0) return [];

      if (mode === "z") {
        return Array.from({ length: hinges }, (_, i) => (i % 2 === 0 ? -closedAngle : closedAngle));
      }

      if (mode === "parallel") {
        // Paralela dupla: fecha em blocos paralelos. Em 4 painéis, os dois primeiros recolhem
        // para um sentido e o último retorna, formando o bloco compacto típico da dobra paralela.
        if (count === 4) return [-closedAngle, -closedAngle, closedAngle];
        return Array.from({ length: hinges }, (_, i) => i < Math.ceil(hinges / 2) ? -closedAngle : closedAngle);
      }

      // Roll-fold/carteira e bi-fold: recolhimento em cadeia, como camadas entrando uma na outra.
      return Array.from({ length: hinges }, () => -closedAngle);
    }

    function buildConnectedChain(count, panelW, mode, t) {
      const closedAngle = 180 * (1 - t);
      const relativeAngles = getPhysicalFoldRelativeAngles(mode, count, closedAngle);
      const panels = [{ x: 0, z: 0, angle: 0 }];

      for (let i = 1; i < count; i++) {
        const prev = panels[i - 1];
        const prevRad = prev.angle * Math.PI / 180;

        // O vinco do próximo painel nasce exatamente na borda direita real do painel anterior.
        // Esta é a correção principal: não há gap, não há folha solta, só geometria encadeada.
        const hingeX = prev.x + Math.cos(prevRad) * panelW;
        const hingeZ = prev.z - Math.sin(prevRad) * panelW;
        panels.push({
          x: hingeX,
          z: hingeZ,
          angle: prev.angle + relativeAngles[i - 1]
        });
      }

      return panels;
    }

    function buildGatePanels(count, panelW, t) {
      const closedAngle = 180 * (1 - t);
      const panels = [];

      if (count <= 2) return buildConnectedChain(count, panelW, "book", t);

      if (count === 3) {
        // Gate-fold real de 2 dobras: painel central fixo, abas laterais presas nos dois vincos.
        panels[0] = { x: 0, z: 0, angle: closedAngle, origin: "right center", side: "left" };
        panels[1] = { x: panelW, z: 0, angle: 0, origin: "left center", side: "center" };
        panels[2] = { x: panelW * 2, z: 0, angle: -closedAngle, origin: "left center", side: "right" };
        return panels;
      }

      // Double-gate / janela com miolo maior: centro fixo e duas portas laterais.
      for (let i = 0; i < count; i++) {
        panels[i] = { x: i * panelW, z: 0, angle: 0, origin: "left center", side: "center" };
      }
      panels[0] = { x: 0, z: 0, angle: closedAngle, origin: "right center", side: "left" };
      panels[count - 1] = { x: (count - 1) * panelW, z: 0, angle: -closedAngle, origin: "left center", side: "right" };
      return panels;
    }

    function getPanelExtents(panel, panelW) {
      const rad = panel.angle * Math.PI / 180;
      if (panel.origin === "right center") {
        const hingeX = panel.x + panelW;
        const hingeZ = panel.z;
        const leftX = hingeX - Math.cos(rad) * panelW;
        const leftZ = hingeZ + Math.sin(rad) * panelW;
        return { minX: Math.min(leftX, hingeX), maxX: Math.max(leftX, hingeX), minZ: Math.min(leftZ, hingeZ), maxZ: Math.max(leftZ, hingeZ) };
      }
      const endX = panel.x + Math.cos(rad) * panelW;
      const endZ = panel.z - Math.sin(rad) * panelW;
      return { minX: Math.min(panel.x, endX), maxX: Math.max(panel.x, endX), minZ: Math.min(panel.z, endZ), maxZ: Math.max(panel.z, endZ) };
    }

    function renderContinuousFold(pageNumbers, opts = {}) {
      const pct = clampNumber(opts.pct ?? 100, 0, 100);
      const t = pct / 100;
      const mode = opts.openingMode || "roll";
      const ratio = getRatio();
      const count = Math.max(1, pageNumbers.length);

      if (count === 1) {
        renderFlatPages([pageNumbers[0]], { cols: 1 });
        return;
      }

      const panelH = count <= 2 ? 430 : 360;
      const panelW = Math.max(120, panelH * (ratio.w / ratio.h));
      const rawPanels = mode === "gate"
        ? buildGatePanels(count, panelW, t)
        : buildConnectedChain(count, panelW, mode === "book" ? "book" : mode, t);

      let minX = Infinity, maxX = -Infinity, minZ = Infinity, maxZ = -Infinity;
      rawPanels.forEach(panel => {
        const e = getPanelExtents(panel, panelW);
        minX = Math.min(minX, e.minX);
        maxX = Math.max(maxX, e.maxX);
        minZ = Math.min(minZ, e.minZ);
        maxZ = Math.max(maxZ, e.maxZ);
      });

      const visualW = Math.max(panelW, maxX - minX);
      const totalW = Math.max(panelW * 1.18, visualW + panelW * 0.34);
      const offsetX = (totalW - visualW) / 2 - minX;
      const depth = Math.max(1, maxZ - minZ);

      // Camera frontal e camera traseira:
      // A dobra fisica continua sendo a mesma. No verso, nao criamos outro folder;
      // invertemos a leitura de profundidade e dos angulos, como uma camera atras
      // do mesmo objeto, mantendo a ordem horizontal dos paineis para o usuario.
      const isBackCamera = opts.cameraSide === "back" || state.folderSide === "back";
      const cameraRy = isBackCamera ? (mode === "z" ? "0deg" : "6deg") : (mode === "z" ? "0deg" : "-6deg");

      const doc = document.createElement("div");
      doc.className = `fold-sim mode-${mode} ${isBackCamera ? "camera-back" : "camera-front"}`;
      doc.style.setProperty("--sim-total-w", `${Math.min(1320, totalW)}px`);
      doc.style.setProperty("--sim-h", `${panelH}px`);
      doc.style.setProperty("--panel-w", `${panelW}px`);
      doc.style.setProperty("--panel-h", `${panelH}px`);
      doc.style.setProperty("--page-w", ratio.w);
      doc.style.setProperty("--page-h", ratio.h);
      doc.style.setProperty("--sim-rx", "0deg");
      doc.style.setProperty("--sim-ry", cameraRy);

      const panelHtml = pageNumbers.map((n, i) => {
        const panel = rawPanels[i];
        const origin = panel.origin || "left center";
        const zLift = mode === "gate"
          ? (panel.side === "center" ? 0 : 2 + i * 0.3)
          : i * 0.85;

        // Camera traseira = mesma dobra vista por tras.
        // Por isso o X fica no mesmo lugar, mas a profundidade e a rotacao aparente
        // invertem. Isso impede o erro de “trocar paginas” sem mudar a perspectiva.
        const visibleAngle = isBackCamera ? -panel.angle : panel.angle;
        const visibleZ = isBackCamera ? -(panel.z + zLift) : (panel.z + zLift);

        const shadeByAngle = Math.min(0.38, Math.abs(panel.angle) / 180 * 0.24);
        const normalizedDepth = isBackCamera
          ? Math.max(0, maxZ - panel.z) / (depth + 1)
          : Math.max(0, panel.z - minZ) / (depth + 1);
        const shadeByDepth = normalizedDepth * 0.08;
        const shade = 1 - Math.min(0.42, shadeByAngle + shadeByDepth);
        const baseZIndex = mode === "gate"
          ? (panel.side === "center" ? 4 : 8 + i)
          : 10 + i;
        const zIndex = isBackCamera ? 100 - baseZIndex : baseZIndex;
        const transform = `translate3d(${(panel.x + offsetX).toFixed(3)}px, 0, ${visibleZ.toFixed(3)}px) rotateY(${visibleAngle.toFixed(4)}deg)`;
        const style = `transform:${transform}; transform-origin:${origin}; filter:brightness(${shade.toFixed(3)}); z-index:${zIndex};`;
        return physicalPageMarkupByNumber(n, {
          style,
          round: `${i === 0 ? "round-left" : ""} ${i === pageNumbers.length - 1 ? "round-right" : ""}`
        });
      }).join("");

      doc.innerHTML = `<div class="fold-sim-inner">${panelHtml}</div>`;
      els.viewer.innerHTML = "";
      els.viewer.appendChild(doc);
    }

    function renderFolder() {
      const fold = currentFold();
      if (state.technicalMode) return renderTechnicalFold();

      const frontPanels = getFolderFrontPanels(fold);
      const backPanels = getFolderBackPanels(frontPanels, fold);
      syncOpenStepFromPct();
      const pct = state.openPct;
      const visibleNumbers = state.folderSide === "back" ? backPanels : frontPanels;

      renderContinuousFold(visibleNumbers, {
        openingMode: fold.openingMode,
        pct,
        cameraSide: state.folderSide
      });

      if (state.folderSide === "back") {
        els.caption.textContent = `Camera traseira em ${Math.round(pct)}% aberto: mesmo folder visto por tras (${frontPanels.map((page, i) => `Pág ${page} ⇄ Pág ${backPanels[i]}`).join(" · ")}).`;
      } else if (pct <= 0.5) {
        els.caption.textContent = `Material fechado. Use a barra de abertura para simular a dobra real.`;
      } else if (pct >= 99.5) {
        els.caption.textContent = `100% aberto: ${frontPanels.map(p => `Pág ${p}`).join(" · ")}. Clique em "Verso" para ver as páginas de trás com a mesma abertura.`;
      } else {
        els.caption.textContent = `${Math.round(pct)}% aberto: as páginas permanecem grudadas e dobram pelo vinco do ${fold.label}.`;
      }
    }

    function panelFlexForPage(pageNumber) {
      const fold = currentFold();
      if (fold.reducedPage !== pageNumber) return 1;
      const main = 100;
      const reduced = Math.max(85, main - Number(state.compensationMm || 0));
      return reduced / main;
    }

    function panelMmForPage(pageNumber) {
      const fold = currentFold();
      if (fold.reducedPage !== pageNumber) return "100 mm";
      return `${Math.max(85, 100 - Number(state.compensationMm || 0))} mm`;
    }

    function renderTechnicalFold() {
      const fold = currentFold();
      const wrap = document.createElement("div");
      wrap.className = "technical-wrap";
      const renderRow = (title, arr, note) => `
        <div class="artboard-block">
          <div class="artboard-title"><span>${title}</span><span>${note}</span></div>
          <div class="artboard-row">
            ${arr.map(p => pageMarkupByNumber(p, { panel: true, title: `Pág ${p}`, badge: `Página ${p}`, flex: panelFlexForPage(p), mm: panelMmForPage(p) })).join("")}
          </div>
        </div>
      `;
      wrap.innerHTML = `
        ${renderRow("Prancheta externa", fold.external, `[${fold.external.join(", ")}]`)}
        ${renderRow("Prancheta interna", fold.internal, `[${fold.internal.join(", ")}]`)}
      `;
      els.viewer.innerHTML = "";
      els.viewer.appendChild(wrap);
      els.caption.textContent = fold.reducedPage
        ? `Modo técnico: a Página ${fold.reducedPage} é a aba interna e recebe compensação de ${state.compensationMm}mm.`
        : `Modo técnico: mapeamento físico das pranchetas externa e interna do ${fold.label}.`;
    }

    function renderFrontBack() {
      const ratio = getRatio();

      // Frente e verso agora usa a mesma regra universal do folder:
      // o verso nunca é fixo no número 2; ele é calculado pelo total real.
      // Em material simples de 2 páginas: Página 1 ⇄ Página 2.
      // Se o fluxo for ampliado futuramente para mais páginas: 1 ⇄ total, 2 ⇄ total-1...
      const totalPages = Math.max(2, expectedCount());
      const frontPanels = frontPanelsForTotal(totalPages);
      const backPanels = backPanelsFor(frontPanels, totalPages);
      const frontPage = frontPanels[0];
      const backPage = backPanels[0];

      if (state.view === "compare") {
        renderFlatPages([frontPage, backPage], { cols: 2, gap: true });
        els.caption.textContent = `Frente e verso lado a lado: Pág ${frontPage} ⇄ Pág ${backPage}.`;
        return;
      }

      const card = document.createElement("div");
      const width = Math.max(280, Math.min(620, 520 * (ratio.w / ratio.h)));
      card.className = `flip-card ${state.view === "back" ? "show-back" : ""}`;
      card.style.setProperty("--doc-width", `${width}px`);
      card.style.setProperty("--page-w", ratio.w);
      card.style.setProperty("--page-h", ratio.h);
      card.innerHTML = `
        <div class="flip-face front">${pageMarkupByNumber(frontPage, { title: "Frente", badge: `Página ${frontPage}` })}</div>
        <div class="flip-face back">${pageMarkupByNumber(backPage, { title: "Verso", badge: `Página ${backPage}` })}</div>
      `;
      els.viewer.innerHTML = "";
      els.viewer.appendChild(card);
      els.caption.textContent = state.view === "back"
        ? `Verso real do material: Pág ${frontPage} ⇄ Pág ${backPage}.`
        : `Frente do material: Pág ${frontPage}. Clique em "Verso" para ver a página de trás calculada automaticamente.`;
    }

    function renderBook() {
      const maxSpread = Math.max(0, Math.floor((state.pageCount - 4) / 2));
      if (state.view === "prevPage") { state.bookSpread = Math.max(0, state.bookSpread - 1); state.view = "spread"; }
      if (state.view === "nextPage") { state.bookSpread = Math.min(maxSpread, state.bookSpread + 1); state.view = "spread"; }
      const ratio = getRatio();
      const width = Math.max(560, Math.min(1050, 430 * (ratio.w / ratio.h) * 2));
      let pages = [];
      let single = false;
      if (state.view === "cover") { pages = [1]; single = true; }
      else if (state.view === "backCover") { pages = [state.pageCount]; single = true; }
      else {
        const left = 2 + state.bookSpread * 2;
        pages = [left, left + 1].filter(p => p <= state.pageCount - 1);
        if (pages.length === 1) single = true;
      }
      const wrap = document.createElement("div");
      wrap.className = `book-wrap ${single ? "single" : "turning"}`;
      wrap.style.setProperty("--doc-width", `${width}px`);
      wrap.style.setProperty("--mobile-doc-width", `${Math.max(760, width)}px`);
      wrap.style.setProperty("--page-w", ratio.w);
      wrap.style.setProperty("--page-h", ratio.h);
      wrap.innerHTML = `${pages.map((p, i) => pageMarkupByNumber(p, { round: `${i === 0 ? "round-left" : ""} ${i === pages.length - 1 ? "round-right" : ""}` })).join("")}${!single ? `<div class="book-spine"></div>` : ""}`;
      els.viewer.innerHTML = "";
      els.viewer.appendChild(wrap);
      if (state.view === "cover") els.caption.textContent = "Capa do livro.";
      else if (state.view === "backCover") els.caption.textContent = "Contracapa do livro.";
      else els.caption.textContent = `Miolo do livro: ${pages.map(p => `Página ${p}`).join(" e ")}.`;
    }

    function scaleBoxDimensions() {
      const maxH = 460;
      const scale = maxH / Math.max(state.boxHeight, state.boxWidth, state.boxDepth * 2.2);
      return {
        w: Math.max(80, state.boxWidth * scale),
        h: Math.max(120, state.boxHeight * scale),
        d: Math.max(45, state.boxDepth * scale)
      };
    }

    function renderPackaging3D() {
      const stage = document.createElement("div");
      stage.className = "three-stage";
      stage.innerHTML = `
        <div class="three-info">Arraste para rotacionar · Scroll para zoom</div>
      `;

      els.viewer.innerHTML = "";
      els.viewer.appendChild(stage);

      initThreeMockup(stage);
      els.caption.textContent = `Mockup 3D real com geometria ${state.boxWidth} × ${state.boxHeight} × ${state.boxDepth}. Cada arte é aplicada em uma face física da embalagem.`;
    }

    function initThreeMockup(container) {
      if (!window.THREE) {
        container.innerHTML = `<div class="three-error">Three.js não carregou. Conecte-se à internet ou baixe a biblioteca para usar o mockup 3D real.</div>`;
        return;
      }

      disposeThreeMockup();

      const scene = new THREE.Scene();
      scene.background = new THREE.Color(0x0b1020);

      const camera = new THREE.PerspectiveCamera(
        42,
        container.clientWidth / container.clientHeight,
        0.1,
        2000
      );

      const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: false });
      renderer.setSize(container.clientWidth, container.clientHeight);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
      renderer.outputEncoding = THREE.sRGBEncoding;
      container.appendChild(renderer.domElement);

      scene.add(new THREE.AmbientLight(0xffffff, 0.62));

      const keyLight = new THREE.DirectionalLight(0xffffff, 0.95);
      keyLight.position.set(10, 14, 10);
      scene.add(keyLight);

      const fillLight = new THREE.DirectionalLight(0x9ddfff, 0.34);
      fillLight.position.set(-12, 4, -10);
      scene.add(fillLight);

      const rimLight = new THREE.DirectionalLight(0xffffff, 0.24);
      rimLight.position.set(0, -8, 12);
      scene.add(rimLight);

      const materials = createThreeMaterials(renderer);
      const geometry = new THREE.BoxGeometry(
        Number(state.boxWidth) || 90,
        Number(state.boxHeight) || 160,
        Number(state.boxDepth) || 55
      );

      const mesh = new THREE.Mesh(geometry, materials);
      scene.add(mesh);

      const edges = new THREE.EdgesGeometry(geometry);
      const edgeLines = new THREE.LineSegments(
        edges,
        new THREE.LineBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.16 })
      );
      mesh.add(edgeLines);

      const floor = new THREE.Mesh(
        new THREE.CircleGeometry(Math.max(state.boxWidth, state.boxDepth) * 1.25, 96),
        new THREE.MeshBasicMaterial({ color: 0x000000, transparent: true, opacity: 0.18 })
      );
      floor.rotation.x = -Math.PI / 2;
      floor.position.y = -(Number(state.boxHeight) || 160) / 2 - 1;
      scene.add(floor);

      const maxDimension = Math.max(Number(state.boxWidth) || 90, Number(state.boxHeight) || 160, Number(state.boxDepth) || 55);
      let distance = maxDimension * 2.35;
      let rotation = {
        x: THREE.MathUtils.degToRad(state.camera.rx || -13),
        y: THREE.MathUtils.degToRad(state.camera.ry || -32)
      };

      distance = distance / (state.camera.zoom || 1);

      let dragging = false;
      let previous = { x: 0, y: 0 };

      renderer.domElement.addEventListener("pointerdown", event => {
        dragging = true;
        previous = { x: event.clientX, y: event.clientY };
        renderer.domElement.setPointerCapture(event.pointerId);
      });

      renderer.domElement.addEventListener("pointermove", event => {
        if (!dragging) return;
        const dx = event.clientX - previous.x;
        const dy = event.clientY - previous.y;
        rotation.y += dx * 0.01;
        rotation.x += dy * 0.01;
        rotation.x = Math.max(-Math.PI / 2 + 0.12, Math.min(Math.PI / 2 - 0.12, rotation.x));
        previous = { x: event.clientX, y: event.clientY };
      });

      renderer.domElement.addEventListener("pointerup", event => {
        dragging = false;
        try { renderer.domElement.releasePointerCapture(event.pointerId); } catch {}
      });

      renderer.domElement.addEventListener("pointercancel", () => {
        dragging = false;
      });

      renderer.domElement.addEventListener("wheel", event => {
        event.preventDefault();
        distance += event.deltaY * 0.055;
        distance = Math.max(maxDimension * 1.05, Math.min(maxDimension * 6, distance));
        state.camera.zoom = Math.max(0.55, Math.min(1.55, maxDimension * 2.35 / distance));
        els.zoomRange.value = String(state.camera.zoom.toFixed(2));
      }, { passive: false });

      const resizeObserver = new ResizeObserver(() => {
        if (!container.clientWidth || !container.clientHeight) return;
        camera.aspect = container.clientWidth / container.clientHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(container.clientWidth, container.clientHeight);
      });
      resizeObserver.observe(container);

      function animate() {
        const frame = requestAnimationFrame(animate);
        threeMockup.frame = frame;

        camera.position.x = distance * Math.sin(rotation.y) * Math.cos(rotation.x);
        camera.position.y = distance * Math.sin(rotation.x);
        camera.position.z = distance * Math.cos(rotation.y) * Math.cos(rotation.x);
        camera.lookAt(0, 0, 0);

        state.camera.rx = THREE.MathUtils.radToDeg(rotation.x);
        state.camera.ry = THREE.MathUtils.radToDeg(rotation.y);

        renderer.render(scene, camera);
      }

      threeMockup = { scene, camera, renderer, mesh, materials, geometry, resizeObserver, frame: null };
      animate();
    }

    function createThreeMaterials(renderer) {
      const placeholder = {
        right: 0x233044,
        left: 0x1f2937,
        top: 0x334155,
        bottom: 0x111827,
        front: 0x475569,
        back: 0x263244
      };

      const order = ["right", "left", "top", "bottom", "front", "back"];
      const imageByFace = {
        right: state.images[1],
        left: state.images[3],
        top: state.images[4],
        bottom: state.images[5],
        front: state.images[0],
        back: state.images[2]
      };

      return order.map(face => {
        const image = imageByFace[face];
        if (!image) {
          return new THREE.MeshStandardMaterial({
            color: placeholder[face],
            roughness: 0.72,
            metalness: 0.02
          });
        }

        const texture = new THREE.TextureLoader().load(image.src);
        texture.anisotropy = renderer.capabilities.getMaxAnisotropy();
        texture.needsUpdate = true;
        if (THREE.sRGBEncoding) texture.encoding = THREE.sRGBEncoding;

        return new THREE.MeshStandardMaterial({
          map: texture,
          roughness: 0.68,
          metalness: 0.02
        });
      });
    }

    let threeMockup = null;

    function disposeThreeMockup() {
      if (!threeMockup) return;
      if (threeMockup.frame) cancelAnimationFrame(threeMockup.frame);
      if (threeMockup.resizeObserver) threeMockup.resizeObserver.disconnect();
      if (threeMockup.geometry) threeMockup.geometry.dispose();
      if (threeMockup.materials) {
        threeMockup.materials.forEach(material => {
          if (material.map) material.map.dispose();
          material.dispose();
        });
      }
      if (threeMockup.renderer) {
        const canvas = threeMockup.renderer.domElement;
        threeMockup.renderer.dispose();
        if (canvas && canvas.parentNode) canvas.parentNode.removeChild(canvas);
      }
      threeMockup = null;
    }

    function renderPackagingFlat() {
      const dim = scaleBoxDimensions();
      const wrap = document.createElement("div");
      wrap.className = "pack-flat";
      wrap.innerHTML = `
        <div class="pack-row"><div class="pack-panel pack-top" style="width:${dim.w}px;height:${dim.d}px;">${faceMarkup(4)}</div></div>
        <div class="pack-row">
          <div class="pack-panel pack-side" style="width:${dim.d}px;height:${dim.h}px;">${faceMarkup(3)}</div>
          <div class="pack-panel pack-front" style="width:${dim.w}px;height:${dim.h}px;">${faceMarkup(0)}</div>
          <div class="pack-panel pack-side" style="width:${dim.d}px;height:${dim.h}px;">${faceMarkup(1)}</div>
          <div class="pack-panel pack-back" style="width:${dim.w}px;height:${dim.h}px;">${faceMarkup(2)}</div>
        </div>
        <div class="pack-row"><div class="pack-panel pack-bottom" style="width:${dim.w}px;height:${dim.d}px;">${faceMarkup(5)}</div></div>`;
      els.viewer.innerHTML = "";
      els.viewer.appendChild(wrap);
      els.caption.textContent = "Planificação da embalagem: laterais, frente, verso, topo e base com dimensões proporcionais.";
    }

    function renderPackaging() { state.view === "packFlat" ? renderPackagingFlat() : renderPackaging3D(); }

    function applyCamera(box = document.getElementById("boxObject")) {
      if (!box) return;
      box.style.setProperty("--rx", `${state.camera.rx}deg`);
      box.style.setProperty("--ry", `${state.camera.ry}deg`);
      box.style.setProperty("--zoom", state.camera.zoom);
    }

    function bindDrag(stage, box) {
      stage.addEventListener("pointerdown", e => { state.drag.active = true; state.drag.x = e.clientX; state.drag.y = e.clientY; stage.setPointerCapture(e.pointerId); });
      stage.addEventListener("pointermove", e => {
        if (!state.drag.active) return;
        const dx = e.clientX - state.drag.x;
        const dy = e.clientY - state.drag.y;
        state.drag.x = e.clientX;
        state.drag.y = e.clientY;
        state.camera.ry += dx * 0.45;
        state.camera.rx -= dy * 0.32;
        state.camera.rx = Math.max(-72, Math.min(48, state.camera.rx));
        applyCamera(box);
      });
      stage.addEventListener("pointerup", e => { state.drag.active = false; try { stage.releasePointerCapture(e.pointerId); } catch {} });
      stage.addEventListener("pointercancel", () => { state.drag.active = false; });
    }

    function renderViewer() {
      if (state.product === "book") return renderBook();
      if (state.product === "frontBack") return renderFrontBack();
      if (state.product === "packaging") return renderPackaging();
      return renderFolder();
    }

    function isFolderStateActive(item) {
      if (state.technicalMode) return item.key === "technical";
      if (item.kind !== "view" && item.kind !== "flip") return false;
      if (item.key === "fullClosed") return state.openPct <= 0 && state.folderSide === "front";
      if (item.key === "fullOpen") return state.openPct >= 100 && state.folderSide === "front";
      if (item.key === "verso") return state.folderSide === "back";
      return false;
    }

    function handleFolderTabClick(item) {
      if (state.technicalMode) { state.view = "technical"; render(); return; }
      if (item.key === "fullClosed") { state.openPct = 0; state.folderSide = "front"; }
      else if (item.key === "fullOpen") { state.openPct = 100; state.folderSide = "front"; }
      else if (item.key === "verso") { state.folderSide = state.folderSide === "back" ? "front" : "back"; }
      syncOpenStepFromPct();
      render();
    }

    function renderTabs() {
      els.stateTabs.innerHTML = "";
      const states = getStates();
      states.forEach(item => {
        const btn = document.createElement("button");
        btn.type = "button";
        const isFolder = state.product === "folder";
        const isActive = isFolder ? isFolderStateActive(item) : state.view === item.key;
        const extraCls = item.kind === "action" ? " btn-action" : item.kind === "flip" ? " btn-flip" : "";
        btn.className = `btn btn-primary${extraCls} ${isActive ? "active" : ""}`;
        btn.textContent = item.key === "verso" && state.folderSide === "back" ? "Frente" : (state.product === "frontBack" && item.key === "back" && state.view === "back" ? "Frente" : item.label);
        btn.addEventListener("click", () => {
          if (isFolder) return handleFolderTabClick(item);
          if (state.product === "frontBack" && item.key === "back" && state.view === "back") {
            state.view = "front";
          } else {
            state.view = item.key;
          }
          render();
        });
        els.stateTabs.appendChild(btn);
      });
      // Barra fluida de abertura para Folder: controla a dobra em porcentagem real.
      if (state.product === "folder" && !state.technicalMode) {
        const pct = Math.round(clampNumber(state.openPct, 0, 100));
        const rangeWrap = document.createElement("div");
        rangeWrap.className = "fold-range-wrap";
        rangeWrap.innerHTML = `
          <div class="fold-range-label"><span>Abertura do material</span><strong>${pct}%</strong></div>
          <input id="foldOpenRange" type="range" min="0" max="100" step="0.1" value="${pct}" aria-label="Porcentagem de abertura">
          <div class="open-progress"><span style="width:${pct}%"></span></div>
        `;
        const input = rangeWrap.querySelector("#foldOpenRange");
        input.addEventListener("input", event => {
          state.openPct = Number(event.target.value);
          requestFolderFluidRender(rangeWrap);
        }, { passive: true });
        input.addEventListener("change", () => {
          syncOpenStepFromPct();
          renderTabs();
          renderViewer();
          updateSummary();
        });
        els.stateTabs.appendChild(rangeWrap);
      }
    }

    function renderUploadList() {
      els.uploadList.innerHTML = "";
      for (let i = 0; i < expectedCount(); i++) {
        const label = document.createElement("label");
        label.className = "file-label";
        const image = state.images[i];
        label.innerHTML = `
          <input type="file" accept="image/*" data-index="${i}">
          <span class="file-number">${i + 1}</span>
          <span class="file-text"><strong>${pageName(i)}</strong><span>${image ? `${image.name} · ${image.width}x${image.height}px` : "Nenhuma imagem enviada"}</span></span>
          <button class="mini-btn" type="button" data-index="${i}" title="Mover para cima">↑</button>
          <span class="file-action">Trocar</span>`;
        label.querySelector("input").addEventListener("change", handleSingleUpload);
        label.querySelector(".mini-btn").addEventListener("click", e => { e.preventDefault(); e.stopPropagation(); moveUp(i); });
        els.uploadList.appendChild(label);
      }
    }

    function moveUp(i) {
      if (i <= 0) return;
      const prev = state.images[i - 1];
      state.images[i - 1] = state.images[i];
      state.images[i] = prev;
      render();
    }

    function loadImage(file, index) {
      return new Promise(resolve => {
        const reader = new FileReader();
        reader.onload = () => {
          const img = new Image();
          img.onload = () => {
            state.images[index] = { name: file.name, src: reader.result, width: img.naturalWidth, height: img.naturalHeight };
            if (index === 0 && state.ratioPreset === "auto") { state.autoW = img.naturalWidth; state.autoH = img.naturalHeight; }
            resolve();
          };
          img.src = reader.result;
        };
        reader.readAsDataURL(file);
      });
    }

    async function handleSingleUpload(e) {
      const file = e.currentTarget.files?.[0];
      const index = Number(e.currentTarget.dataset.index);
      if (!file) return;
      await loadImage(file, index);
      render();
    }

    async function handleBulk(files) {
      const list = [...files].filter(file => file.type.startsWith("image/")).slice(0, expectedCount());
      for (let i = 0; i < list.length; i++) await loadImage(list[i], i);
      render();
    }

    function renderReview() {
      const items = [];
      const uploaded = uploadedCount();
      const count = expectedCount();
      if (uploaded === 0) items.push({ type: "warn", text: "Nenhuma imagem enviada ainda. Use o upload em massa para acelerar." });
      else if (uploaded < count) items.push({ type: "warn", text: `Você enviou ${uploaded} de ${count} imagens. Ainda faltam ${count - uploaded}.` });
      else items.push({ type: "ok", text: `Todas as ${count} imagens esperadas foram enviadas.` });

      if (state.product === "folder") {
        const fold = currentFold();
        items.push({ type: "ok", text: `Imposição ${fold.label}: externa [${fold.external.join(", ")}], interna [${fold.internal.join(", ")}].` });
        if (fold.reducedPage) items.push({ type: "warn", text: `A Página ${fold.reducedPage} é aba interna e está com compensação visual de ${state.compensationMm}mm.` });
      }

      if (state.ratioPreset === "auto" && !state.autoW && state.product !== "packaging") items.push({ type: "warn", text: "A proporção automática será definida pela primeira imagem enviada." });

      const imageEntries = Object.values(state.images).filter(Boolean);
      if (imageEntries.length > 1 && state.product !== "packaging") {
        const base = imageEntries[0].width / imageEntries[0].height;
        const mismatch = imageEntries.some(img => Math.abs((img.width / img.height) - base) > 0.05);
        items.push(mismatch ? { type: "danger", text: "Há imagens com proporções diferentes. Pode haver cortes ou desalinhamento." } : { type: "ok", text: "As imagens têm proporções compatíveis entre si." });
      }
      const low = imageEntries.find(img => img.width < 900 || img.height < 900);
      if (low) items.push({ type: "warn", text: "Uma ou mais imagens parecem ter resolução baixa para apresentação em tela grande." });
      if (state.product === "packaging") items.push({ type: "ok", text: `Geometria 3D: largura ${state.boxWidth}, altura ${state.boxHeight}, profundidade ${state.boxDepth}.` });

      els.reviewList.innerHTML = items.map(item => `<div class="review-item ${item.type === "ok" ? "" : item.type}"><span class="review-dot"></span><span>${item.text}</span></div>`).join("");
    }

    function updateUIVisibility() {
      els.folderModelField.classList.toggle("hidden", state.product !== "folder");
      els.pageCountField.classList.toggle("hidden", state.product === "frontBack" || state.product === "packaging" || state.product === "folder");
      els.ratioField.classList.toggle("hidden", state.product === "packaging");
      els.customRatioFields.classList.toggle("hidden", state.ratioPreset !== "custom" || state.product === "packaging");
      els.foldTechnicalFields.classList.toggle("hidden", state.product !== "folder");
      els.compensationField.classList.add("hidden");
      els.packagingFields.classList.toggle("hidden", state.product !== "packaging");
      els.resetCameraBtn.classList.toggle("hidden", state.product !== "packaging" || state.view !== "box3d");
      els.zoomRange.value = String(state.camera.zoom);
    }

    function updateSummary() {
      const model = state.product === "folder" ? currentFold().label : state.product === "packaging" ? state.packageType : getRatio().text;
      els.summaryProject.textContent = productLabel();
      els.summaryModel.textContent = model;
      els.summaryStatus.textContent = `${uploadedCount()} / ${expectedCount()} imagens`;
      els.toggleTitles.textContent = state.showTitles ? "Ocultar títulos" : "Mostrar títulos";
      els.toggleImages.textContent = state.showImages ? "Ocultar imagens" : "Mostrar imagens";
      els.presentationBtn.textContent = state.presentation ? "Sair da apresentação" : "Modo apresentação";
      document.body.classList.toggle("hide-titles", !state.showTitles);
      document.body.classList.toggle("hide-images", !state.showImages);
      document.body.classList.toggle("presentation", state.presentation);
      [...els.productCards.querySelectorAll(".project-card")].forEach(card => card.classList.toggle("active", card.dataset.product === state.product));
    }

    function render() {
      normalize();
      renderTabs();
      renderViewer();
      renderUploadList();
      renderReview();
      updateUIVisibility();
      updateSummary();
    }

    function syncControls() {
      const previousFold = state.foldModel;
      state.foldModel = els.foldModel.value;
      if (previousFold !== state.foldModel) {
        state.openPct = 100;
        syncOpenStepFromPct();
        state.folderSide = "front";
      }
      state.pageCount = Number(els.pageCount.value);
      state.ratioPreset = els.ratioPreset.value;
      state.customW = Number(els.customW.value) || 1;
      state.customH = Number(els.customH.value) || 1;
      state.technicalMode = els.technicalMode.checked;
      state.compensationMm = Number(els.compensationMm.value) || 0;
      state.packageType = els.packageType.value;
      state.boxWidth = Number(els.boxWidth.value) || 90;
      state.boxHeight = Number(els.boxHeight.value) || 160;
      state.boxDepth = Number(els.boxDepth.value) || 55;
      state.camera.zoom = Number(els.zoomRange.value) || 1;
      if (state.product === "folder") state.pageCount = currentFold().pages;
      render();
    }

    function bindEvents() {
      els.productCards.addEventListener("click", e => {
        const card = e.target.closest(".project-card");
        if (!card) return;
        state.product = card.dataset.product;
        if (state.product === "book") { state.pageCount = 8; state.view = "cover"; }
        if (state.product === "folder") {
          state.pageCount = currentFold().pages;
          state.openPct = 100;
          syncOpenStepFromPct();
          state.folderSide = "front";
          state.view = state.technicalMode ? "technical" : "front";
        }
        if (state.product === "frontBack") { state.pageCount = 2; state.view = "front"; }
        if (state.product === "packaging") { state.pageCount = 6; state.view = "box3d"; }
        els.pageCount.value = String(state.pageCount);
        render();
      });

      [els.foldModel, els.pageCount, els.ratioPreset, els.customW, els.customH, els.technicalMode, els.compensationMm, els.packageType, els.boxWidth, els.boxHeight, els.boxDepth, els.zoomRange]
        .forEach(el => { el.addEventListener("input", syncControls); el.addEventListener("change", syncControls); });

      els.bulkUpload.addEventListener("change", e => handleBulk(e.currentTarget.files || []));
      ["dragenter", "dragover"].forEach(type => els.bulkDrop.addEventListener(type, e => { e.preventDefault(); els.bulkDrop.classList.add("dragging"); }));
      ["dragleave", "drop"].forEach(type => els.bulkDrop.addEventListener(type, e => { e.preventDefault(); els.bulkDrop.classList.remove("dragging"); }));
      els.bulkDrop.addEventListener("drop", e => handleBulk(e.dataTransfer.files || []));

      els.toggleTitles.addEventListener("click", () => { state.showTitles = !state.showTitles; updateSummary(); });
      els.toggleImages.addEventListener("click", () => { state.showImages = !state.showImages; updateSummary(); });
      els.presentationBtn.addEventListener("click", () => { state.presentation = !state.presentation; updateSummary(); });
      els.resetCameraBtn.addEventListener("click", () => { state.camera = { rx: -13, ry: -32, zoom: 1 }; els.zoomRange.value = "1"; applyCamera(); });
    }

    function init() {
      // comeca com o folder 100% aberto pra mostrar o efeito de abertura
      if (state.product === "folder") {
        state.openPct = 100;
        syncOpenStepFromPct();
      }
      els.foldModel.value = state.foldModel;
      els.pageCount.value = String(state.pageCount);
      els.ratioPreset.value = state.ratioPreset;
      els.customW.value = String(state.customW);
      els.customH.value = String(state.customH);
      els.technicalMode.checked = state.technicalMode;
      els.compensationMm.value = String(state.compensationMm);
      els.packageType.value = state.packageType;
      els.boxWidth.value = String(state.boxWidth);
      els.boxHeight.value = String(state.boxHeight);
      els.boxDepth.value = String(state.boxDepth);
      els.zoomRange.value = String(state.camera.zoom);
      bindEvents();
      render();
    }

    init();
  </script>
</body>
</htm>
