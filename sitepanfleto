        folds: 2,
        external: [6, 1, 2],
        internal: [5, 4, 3],
        reducedPage: null,
        states: MULTIFOLD_STATES
      },
      gatefold: {
        label: "Gate-fold / Porta (2 dobras | 6 paginas)",
        openingMode: "gate",
        pages: 6,
        folds: 2,
